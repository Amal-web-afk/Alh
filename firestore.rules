rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Config: Anyone can view (reads), but ONLY authenticated admins in the white-list defaults can modify (write)
    match /config/{document} {
      allow read: if true;
      allow write: if request.auth != null && 
                     request.auth.token.email.toLowerCase() in get(/databases/$(database)/documents/config/default).data.admins;
    }

    // Products: Anyone can view catalog, ONLY authenticated admins can write/edit/delete product profiles
    match /products/{document} {
      allow read: if true;
      allow write: if request.auth != null && 
                     request.auth.token.email.toLowerCase() in get(/databases/$(database)/documents/config/default).data.admins;
    }

    // Orders: Anyone (including guest checkouts) can write (create) new orders.
    // Users can read/write their own orders, and admins can view/update all global orders.
    match /orders/{document} {
      allow create: if true;
      allow read, update: if (request.auth != null && 
                            (request.auth.uid == resource.data.userId || 
                             request.auth.token.email.toLowerCase() in get(/databases/$(database)/documents/config/default).data.admins)) || 
                           (resource == null); // Allow initial checkouts
      allow delete: if request.auth != null && 
                      request.auth.token.email.toLowerCase() in get(/databases/$(database)/documents/config/default).data.admins;
    }

    // Users profiles: Users can only read or write their own private document
    match /users/{document} {
      allow read, write: if request.auth != null && request.auth.uid == document;
    }
  }
}
